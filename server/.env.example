PORT=3000
AUTH_TOKEN=your-secret-token-here

# ================================
# FRP 内网穿透配置
# ================================

# 是否启用 FRP (true/false)
FRP_ENABLED=false

# FRP 服务端地址
FRP_SERVER_HOST=your-frp-server.com

# FRP 服务端端口 (默认 7000)
FRP_SERVER_PORT=7000

# FRP 认证令牌 (与服务端 frps.toml 中的 token 一致)
FRP_TOKEN=your-frp-token

# 远程映射端口 (即公网服务器上要开放的端口)
FRP_REMOTE_PORT=8300

# 隧道名称 (可选，用于标识)
FRP_TUNNEL_NAME=tarotora

# FRP 客户端可执行文件路径 (可选，如不在 PATH 中需要指定)
# FRPC_PATH=C:\frp\frpc.exe
